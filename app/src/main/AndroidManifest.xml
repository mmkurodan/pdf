<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
        Reading input files uses SAF (no permission needed). Writing output to
        the public Download folder uses MediaStore on Android 10+ (no permission);
        only Android 9 and below need WRITE_EXTERNAL_STORAGE, so it is capped at
        API 28.
    -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!-- Only used for the optional, one-time OCR model (traineddata) download.
         After download, OCR runs fully offline. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Package visibility (Android 11+) for the companion LLM Tester app, so its
         launch intent/service can be resolved from the LLM settings screen. -->
    <queries>
        <package android:name="com.micklab.llama" />
    </queries>

    <application
        android:name=".PdfToolsApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:theme="@style/Theme.PdfTools">

        <!-- AdMob アプリ ID（未設定だと MobileAds 初期化時にクラッシュ） -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-3062461524889254~1542365697" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.PdfTools">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Exposes generated files (shared PDFs/images/JSON) to other apps. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!--
            WorkManager is initialized on-demand through Hilt
            (Configuration.Provider on the Application), so the default
            automatic initializer is removed here.
        -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

    </application>

</manifest>
